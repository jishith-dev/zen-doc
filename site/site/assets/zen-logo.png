<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="100" height="100">
  <defs>
    <linearGradient id="zGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff79c6"/>
      <stop offset="100%" style="stop-color:#bd93f9"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="100" height="100" rx="22" fill="#1e1f29"/>

  <!-- Clean minimal Z using strokes only -->
  <polyline
    points="28,28 72,28 28,72 72,72"
    fill="none"
    stroke="url(#zGrad)"
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
